{
  "name": "meridian-chart",
  "private": true,
  "version": "0.1.0",
  "description": "A navigational chart of your code: local-first call graphs drawn as a 19th-century nautical chart, plus an MCP server so agents can read them.",
  "license": "MIT",
  "repository": "github:RicardoMaas7/meridian",
  "type": "module",
  "bin": {
    "meridian-mcp": "dist-mcp/server.mjs"
  },
  "files": [
    "dist-mcp",
    "public/wasm"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:mcp": "esbuild mcp/server.ts --bundle --platform=node --target=node20 --format=esm --packages=external --outfile=dist-mcp/server.mjs",
    "prepare": "npm run build:mcp",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "d3-force": "^3.0.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "web-tree-sitter": "^0.26.9",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/d3-force": "^3.0.10",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "esbuild": "^0.28.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "tree-sitter-c": "^0.24.1",
    "tree-sitter-cpp": "^0.23.4",
    "tree-sitter-go": "^0.25.0",
    "tree-sitter-java": "^0.23.5",
    "tree-sitter-javascript": "^0.25.0",
    "tree-sitter-python": "^0.25.0",
    "tree-sitter-rust": "^0.24.0",
    "tree-sitter-typescript": "^0.23.2",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12"
  }
}
